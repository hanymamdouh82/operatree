# OperaTree Demo
# Run with: vhs demo.tape
# Requires: vhs (https://github.com/charmbracelet/vhs)
#           operatree installed (make install)

# -------------------------------------------------------------------
# Output
# -------------------------------------------------------------------

Output ./operatree-demo.gif
Output ./operatree-demo.mp4

# -------------------------------------------------------------------
# Terminal settings
# -------------------------------------------------------------------

Set Shell       "bash"
Set FontSize    14
# Set FontFamily  "JetBrains Mono"
Set Width       1200
Set Height      700
Set Theme       "Dracula"
Set Padding     20
Set Framerate   30

# -------------------------------------------------------------------
# Setup — clean slate
# -------------------------------------------------------------------

Hide
  Type "rm -rf /tmp/operatree-demo && mkdir -p /tmp/operatree-demo"
  Enter
  Sleep 500ms
Show

# -------------------------------------------------------------------
# 1. Welcome
# -------------------------------------------------------------------

Type "operatree"
Sleep 500ms
Enter
Sleep 2s

# -------------------------------------------------------------------
# 2. Initialize config
# -------------------------------------------------------------------

Sleep 1s
Type "# Initialize OperaTree for the first time"
Sleep 1s
Enter
Sleep 500ms

Type "operatree init"
Enter
Sleep 1s

# Answer the init form: standard projects directory
Type "/tmp/operatree-demo"
Sleep 500ms
Enter
Sleep 2s

# -------------------------------------------------------------------
# 3. Bootstrap a project
# -------------------------------------------------------------------

Sleep 1s
Type "# Bootstrap a new project"
Sleep 1s
Enter
Sleep 500ms

Type "operatree bootstrap emissions-validation"
Enter
Sleep 3s

# -------------------------------------------------------------------
# 4. Describe the fresh project
# -------------------------------------------------------------------

Sleep 1s
Type "# Describe the project structure"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation desc"
Enter
Sleep 3s

# -------------------------------------------------------------------
# 5. Create an event
# -------------------------------------------------------------------

Sleep 1s
Type "# Create a new event"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation new event"
Enter
Sleep 1s

# Name
Type "Site Visit - Cairo Plant"
Sleep 300ms
Enter
Sleep 500ms

# Date — accept default (today)
Enter
Sleep 500ms

# Tags
Type "emissions, site-visit, cairo, measurement"
Sleep 300ms
Enter
Sleep 500ms

# Notes
Type "First on-site measurement session at the Cairo plant"
Sleep 300ms
Enter
Sleep 500ms

# Location
Type "Cairo Industrial Zone"
Sleep 300ms
Enter
Sleep 500ms

# Participants
Type "Hany Mamdouh, Ahmed Sayed, Sara Ali"
Sleep 300ms
Enter
Sleep 2s

# -------------------------------------------------------------------
# 6. Create a task
# -------------------------------------------------------------------

Sleep 1s
Type "# Create a new task"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation new task"
Enter
Sleep 1s

# Name
Type "Prepare Emissions Report"
Sleep 300ms
Enter
Sleep 500ms

# Date
Enter
Sleep 500ms

# Tags
Type "report, emissions, deliverable"
Sleep 300ms
Enter
Sleep 500ms

# Notes
Type "Compile all measurement data into the final client report"
Sleep 300ms
Enter
Sleep 500ms

# Owner
Type "Hany Mamdouh"
Sleep 300ms
Enter
Sleep 500ms

# Status — select in-progress
Down
Sleep 300ms
Enter
Sleep 500ms

# Related event — select first
Enter
Sleep 2s

# -------------------------------------------------------------------
# 7. Create a topic
# -------------------------------------------------------------------

Sleep 1s
Type "# Create a knowledge topic"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation new topic"
Enter
Sleep 1s

# Name
Type "Emissions Measurement Standards"
Sleep 300ms
Enter
Sleep 500ms

# Date
Enter
Sleep 500ms

# Tags
Type "standards, ISO, emissions"
Sleep 300ms
Enter
Sleep 500ms

# Notes
Type "Overview of ISO 14064 and local regulatory standards"
Sleep 300ms
Enter
Sleep 2s

# -------------------------------------------------------------------
# 8. Project summary
# -------------------------------------------------------------------

Sleep 1s
Type "# Project at a glance"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation summary"
Enter
Sleep 3s

# -------------------------------------------------------------------
# 9. Fuzzy find — open browser
# -------------------------------------------------------------------

Sleep 1s
Type "# Find anything across all metadata"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation find cairo"
Enter
Sleep 2s

# Navigate the finder — just show it working
Sleep 1s
Down
Sleep 500ms
Up
Sleep 500ms
Enter
Sleep 2s

# -------------------------------------------------------------------
# 10. Find with type filter
# -------------------------------------------------------------------

Sleep 1s
Type "# Filter by type and search term"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation find task report"
Enter
Sleep 2s
Enter
Sleep 2s

# -------------------------------------------------------------------
# 11. Explain
# -------------------------------------------------------------------

Sleep 1s
Type "# Built-in directory philosophy guide"
Sleep 1s
Enter
Sleep 500ms

Type "operatree explain"
Enter
Sleep 3s

# -------------------------------------------------------------------
# 12. Pipe-friendly output
# -------------------------------------------------------------------

Sleep 1s
Type "# Works with standard UNIX tools"
Sleep 1s
Enter
Sleep 500ms

Type "operatree -d /tmp/operatree-demo/emissions-validation desc --plain | grep name"
Enter
Sleep 2s

# -------------------------------------------------------------------
# End
# -------------------------------------------------------------------

Sleep 1s
Type "# github.com/hanymamdouh82/operatree"
Sleep 3s
Enter
Sleep 2s
